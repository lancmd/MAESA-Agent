{
  "protocol_version": "1.0",
  "backends": {
    "envi": {
      "transport": "socket",
      "host": "127.0.0.1",
      "port": 9882,
      "capabilities": ["envi.supervised_classification", "system.job_status", "system.list_outputs"]
    },
    "plus": {
      "transport": "http",
      "url": "http://127.0.0.1:9883/commands",
      "capabilities": ["plus.run_scenario", "system.job_status", "system.list_outputs"]
    },
    "arcgis": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/local_backend.py", "--backend", "arcgis"],
      "capabilities": ["arcgis.run_operations", "dataset.inspect"]
    },
    "invest": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/local_backend.py", "--backend", "invest"],
      "capabilities": ["invest.run_carbon", "invest.run_model"]
    },
    "pytorch": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/pytorch_backend.py"],
      "capabilities": ["pytorch.validate_model", "pytorch.run_lulc_inference"]
    },
    "project": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/project_backend.py"],
      "capabilities": ["project.validate"]
    },
    "ecosystem": {
      "transport": "command",
      "command": ["{python}", "{skill_root}/scripts/ecosystem_backend.py"],
      "capabilities": ["ecosystem.evaluate", "ecosystem.tradeoff_analysis", "ecosystem.scenario_compare", "ecosystem.water_yield_calibration", "ecosystem.geodetector_factor_analysis"]
    }
  }
}
